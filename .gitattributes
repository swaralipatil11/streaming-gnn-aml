# Auto-detect text files and perform LF normalization on checkin
* text=auto eol=lf

# Force bash scripts, docker configurations, Python scripts and JSX to LF
*.py text eol=lf
*.sh text eol=lf
*.jsx text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
Dockerfile text eol=lf
.gitignore text eol=lf

# Mark binary files to keep them unaltered
*.pth binary
*.pth.tar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
